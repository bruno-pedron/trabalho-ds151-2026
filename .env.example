# URL do projeto Supabase
# Exemplo: https://xyzabc.supabase.co
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (cliente)
# Use para conectar do app (seguro, pois usa RLS quando implementado)
# Não expõe dados sensíveis sem RLS corretamente configurado
SUPABASE_ANON_KEY=seu_anon_key_aqui